# ----------------------------------------------------------------------------
# Scholar Agent — environment configuration
# Copy this file to ".env" and fill in your values.  ".env" is git-ignored.
# ----------------------------------------------------------------------------

# --- LLM server (your remote box running Qwen / Gemma) ----------------------
# API style of your server:  "ollama"  (native /api/chat)  |  "openai" (/v1/chat/completions)
LLM_PROVIDER=ollama
# Base URL of the server. Examples:
#   Ollama:           http://192.168.1.50:11434
#   OpenAI-compatible: http://192.168.1.50:8000/v1   (vLLM, LM Studio, llama.cpp, etc.)
LLM_BASE_URL=http://localhost:11434
# Leave blank if the server needs no auth.
LLM_API_KEY=
# Model names EXACTLY as your server lists them.
SUMMARY_MODEL=qwen2.5:7b-instruct
JUDGE_MODEL=gemma2:9b
# Context window (tokens) and request timeout (ms).
LLM_NUM_CTX=8192
LLM_TIMEOUT_MS=120000

# --- Semantic Scholar (academic search) -------------------------------------
# Optional API key (raises rate limits). Request: https://www.semanticscholar.org/product/api
S2_API_KEY=
S2_BASE_URL=https://api.semanticscholar.org/graph/v1

# --- Pipeline defaults ------------------------------------------------------
TOP_K=5
MAX_ROUNDS=2
# Parallel LLM calls. Keep at 1 for a single-GPU server; raise if the server can batch.
LLM_CONCURRENCY=1

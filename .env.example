# Summarizer (worker) model — any OpenAI-compatible endpoint
LLM_PROVIDER=openai
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=
SUMMARY_MODEL=qwen3-14b
LLM_NUM_CTX=8192
LLM_TIMEOUT_MS=120000
LLM_DISABLE_THINKING=true

# Judge model — its own endpoint (falls back to the summarizer's if unset).
# Use a different model family so it never grades its own work.
JUDGE_LLM_PROVIDER=openai
JUDGE_LLM_BASE_URL=http://localhost:8001/v1
JUDGE_LLM_API_KEY=
JUDGE_MODEL=gemma-4-e2b
JUDGE_LLM_DISABLE_THINKING=false

# Semantic Scholar (key is optional, raises your rate limit)
S2_API_KEY=
S2_BASE_URL=https://api.semanticscholar.org/graph/v1

# Pipeline tuning
TOP_K=5
MAX_ROUNDS=2
LLM_CONCURRENCY=1
